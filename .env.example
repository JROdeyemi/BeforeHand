# Postgres connection string (Neon: copy from the Neon console, pooled connection)
DATABASE_URL="postgres://user:password@host/beforehand?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Resend (https://resend.com) — powers magic-link sign-in, invitations, nudges
AUTH_RESEND_KEY=""
EMAIL_FROM="Beforehand <hello@yourdomain.com>"

# Canonical app URL (used in emails)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
